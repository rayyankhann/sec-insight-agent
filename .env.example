# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Environment variable template for SEC Insight Agent
#
# INSTRUCTIONS:
#   1. Copy this file to .env:   cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit your .env file to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Your OpenAI API key — required for the agent backend (GPT-4o)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Service URLs ─────────────────────────────────────────────────────────────
# URL of the MCP server — used by the agent backend to call EDGAR tools
# In production, replace with the deployed MCP server URL
MCP_SERVER_URL=http://localhost:8001

# ── Port Configuration ───────────────────────────────────────────────────────
# Port for the agent backend (FastAPI)
AGENT_PORT=8000

# Port for the MCP server (FastAPI)
MCP_PORT=8001

# ── Production Deployment ────────────────────────────────────────────────────
# Set these when deploying to Railway + Vercel (leave blank for local dev)

# Agent backend: comma-separated list of allowed frontend origins (for CORS)
# Example: https://sec-insight-agent.vercel.app
ALLOWED_ORIGINS=

# MCP server: set to the Railway agent backend URL so it accepts requests from it
# Example: https://sec-agent-backend-production.up.railway.app
# ALLOWED_ORIGINS=

# Frontend (Vercel): URL of the deployed agent backend
# Example: https://sec-agent-backend-production.up.railway.app
VITE_API_URL=

# Frontend (Vercel): URL of the deployed MCP server — used by StockCard for quotes
# Example: https://sec-mcp-server-production.up.railway.app
# In local dev this is proxied automatically via Vite (/mcp → localhost:8001)
VITE_MCP_URL=

# ── Cloudflare Browser Rendering ─────────────────────────────────────────────
# Used to fetch SEC filing documents via a real headless Chrome browser.
# Falls back to regex-based HTML stripping if not set.
# Get your token at: dash.cloudflare.com → Profile → API Tokens
# Permission: Account → Browser Rendering → Edit
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
